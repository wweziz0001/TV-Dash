generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum LayoutType {
  LAYOUT_1X1
  LAYOUT_2X2
  LAYOUT_3X3
  LAYOUT_FOCUS_1_2
  LAYOUT_FOCUS_1_4
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  email        String        @unique
  username     String        @unique
  passwordHash String
  role         UserRole      @default(USER)
  favorites    Favorite[]
  savedLayouts SavedLayout[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ChannelGroup {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  sortOrder Int       @default(0)
  channels  Channel[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Channel {
  id           String        @id @default(uuid()) @db.Uuid
  name         String
  slug         String        @unique
  logoUrl      String?
  masterHlsUrl String
  groupId      String?       @db.Uuid
  group        ChannelGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  favorites    Favorite[]
  layoutItems  SavedLayoutItem[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Favorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  channelId String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, channelId])
}

model SavedLayout {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String            @db.Uuid
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  layoutType LayoutType
  configJson Json
  items      SavedLayoutItem[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model SavedLayoutItem {
  id               String      @id @default(uuid()) @db.Uuid
  savedLayoutId    String      @db.Uuid
  savedLayout      SavedLayout @relation(fields: [savedLayoutId], references: [id], onDelete: Cascade)
  tileIndex        Int
  channelId        String?     @db.Uuid
  channel          Channel?    @relation(fields: [channelId], references: [id], onDelete: SetNull)
  preferredQuality String?
  isMuted          Boolean     @default(true)

  @@unique([savedLayoutId, tileIndex])
}

