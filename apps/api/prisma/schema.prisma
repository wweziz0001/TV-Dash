generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum LayoutType {
  LAYOUT_1X1
  LAYOUT_2X2
  LAYOUT_3X3
  LAYOUT_FOCUS_1_2
  LAYOUT_FOCUS_1_4
}

enum StreamPlaybackMode {
  DIRECT
  PROXY
}

enum ChannelSourceMode {
  MASTER_PLAYLIST
  MANUAL_VARIANTS
}

enum EpgSourceType {
  XMLTV_URL
  XMLTV_FILE
}

enum EpgImportStatus {
  NEVER_IMPORTED
  SUCCEEDED
  FAILED
}

enum ProgramEntrySource {
  IMPORTED
  MANUAL
}

enum PlaybackSessionType {
  SINGLE_VIEW
  MULTIVIEW
}

enum PlaybackSessionState {
  idle
  loading
  playing
  buffering
  retrying
  error
}

enum RecordingMode {
  IMMEDIATE
  TIMED
  SCHEDULED
  EPG
}

enum RecordingJobStatus {
  PENDING
  SCHEDULED
  RECORDING
  COMPLETED
  FAILED
  CANCELED
}

enum RecordingRunStatus {
  STARTING
  RECORDING
  COMPLETED
  FAILED
  CANCELED
}

model User {
  id               String            @id @default(uuid()) @db.Uuid
  email            String            @unique
  username         String            @unique
  passwordHash     String
  role             UserRole          @default(USER)
  sessionVersion   Int               @default(0)
  favorites        Favorite[]
  savedLayouts     SavedLayout[]
  playbackSessions PlaybackSession[]
  recordingJobs    RecordingJob[]
  auditEvents      AuditEvent[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model ChannelGroup {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  sortOrder Int       @default(0)
  channels  Channel[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Channel {
  id                String                  @id @default(uuid()) @db.Uuid
  name              String
  slug              String                  @unique
  logoUrl           String?
  sourceMode        ChannelSourceMode       @default(MASTER_PLAYLIST)
  masterHlsUrl      String?
  playbackMode      StreamPlaybackMode      @default(DIRECT)
  upstreamUserAgent String?
  upstreamReferrer  String?
  upstreamHeaders   Json?
  groupId           String?                 @db.Uuid
  group             ChannelGroup?           @relation(fields: [groupId], references: [id], onDelete: SetNull)
  isActive          Boolean                 @default(true)
  sortOrder         Int                     @default(0)
  qualityVariants   ChannelQualityVariant[]
  epgMapping        EpgChannelMapping?
  manualPrograms    ProgramEntry[]
  favorites         Favorite[]
  layoutItems       SavedLayoutItem[]
  playbackSessions  PlaybackSession[]
  recordingJobs     RecordingJob[]
  recordingAssets   RecordingAsset[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
}

model ChannelQualityVariant {
  id          String   @id @default(uuid()) @db.Uuid
  channelId   String   @db.Uuid
  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  label       String
  sortOrder   Int
  playlistUrl String
  width       Int?
  height      Int?
  bandwidth   Int?
  codecs      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([channelId, sortOrder])
  @@index([channelId, isActive, sortOrder])
}

model EpgSource {
  id                     String             @id @default(uuid()) @db.Uuid
  name                   String
  slug                   String             @unique
  sourceType             EpgSourceType      @default(XMLTV_URL)
  url                    String?
  uploadedFileName       String?
  isActive               Boolean            @default(true)
  refreshIntervalMinutes Int?
  requestUserAgent       String?
  requestReferrer        String?
  requestHeaders         Json?
  lastImportStartedAt    DateTime?
  lastImportedAt         DateTime?
  lastImportStatus       EpgImportStatus    @default(NEVER_IMPORTED)
  lastImportMessage      String?
  lastImportChannelCount Int?
  lastImportProgramCount Int?
  sourceChannels         EpgSourceChannel[]
  importedPrograms       ProgramEntry[]
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
}

model EpgSourceChannel {
  id           String             @id @default(uuid()) @db.Uuid
  sourceId     String             @db.Uuid
  source       EpgSource          @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  externalId   String
  displayName  String
  displayNames Json?
  iconUrl      String?
  isAvailable  Boolean            @default(true)
  lastSeenAt   DateTime?
  mapping      EpgChannelMapping?
  programs     ProgramEntry[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([sourceId, externalId])
  @@index([sourceId, isAvailable, displayName])
}

model EpgChannelMapping {
  id              String           @id @default(uuid()) @db.Uuid
  channelId       String           @unique @db.Uuid
  channel         Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sourceChannelId String           @unique @db.Uuid
  sourceChannel   EpgSourceChannel @relation(fields: [sourceChannelId], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model ProgramEntry {
  id                String             @id @default(uuid()) @db.Uuid
  sourceKind        ProgramEntrySource
  sourceId          String?            @db.Uuid
  source            EpgSource?         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceChannelId   String?            @db.Uuid
  sourceChannel     EpgSourceChannel?  @relation(fields: [sourceChannelId], references: [id], onDelete: Cascade)
  channelId         String?            @db.Uuid
  channel           Channel?           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  externalProgramId String?
  title             String
  subtitle          String?
  description       String?
  category          String?
  imageUrl          String?
  startAt           DateTime
  endAt             DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  recordingJobs     RecordingJob[]

  @@index([channelId, sourceKind, startAt])
  @@index([sourceChannelId, startAt])
  @@index([sourceId, sourceKind, startAt])
}

model RecordingJob {
  id                  String             @id @default(uuid()) @db.Uuid
  channelId           String?            @db.Uuid
  channel             Channel?           @relation(fields: [channelId], references: [id], onDelete: SetNull)
  channelNameSnapshot String
  channelSlugSnapshot String
  programEntryId      String?            @db.Uuid
  programEntry        ProgramEntry?      @relation(fields: [programEntryId], references: [id], onDelete: SetNull)
  createdByUserId     String             @db.Uuid
  createdByUser       User               @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  title               String
  requestedQualitySelector String?
  requestedQualityLabel String?
  mode                RecordingMode
  status              RecordingJobStatus @default(PENDING)
  startAt             DateTime
  endAt               DateTime?
  actualStartAt       DateTime?
  actualEndAt         DateTime?
  failureReason       String?
  cancellationReason  String?
  runs                RecordingRun[]
  asset               RecordingAsset?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([createdByUserId, status, startAt])
  @@index([channelId, startAt])
  @@index([programEntryId, startAt])
  @@index([status, startAt])
}

model RecordingRun {
  id              String             @id @default(uuid()) @db.Uuid
  recordingJobId  String             @db.Uuid
  recordingJob    RecordingJob       @relation(fields: [recordingJobId], references: [id], onDelete: Cascade)
  status          RecordingRunStatus @default(STARTING)
  storagePath     String
  outputFileName  String
  containerFormat String
  ffmpegPid       Int?
  startedAt       DateTime?
  endedAt         DateTime?
  exitCode        Int?
  exitSignal      String?
  failureReason   String?
  stderrTail      String?
  fileSizeBytes   BigInt?
  durationSeconds Int?
  asset           RecordingAsset?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([storagePath])
  @@index([recordingJobId, createdAt])
  @@index([status, createdAt])
}

model RecordingAsset {
  id                  String       @id @default(uuid()) @db.Uuid
  recordingJobId      String       @unique @db.Uuid
  recordingJob        RecordingJob @relation(fields: [recordingJobId], references: [id], onDelete: Cascade)
  recordingRunId      String       @unique @db.Uuid
  recordingRun        RecordingRun @relation(fields: [recordingRunId], references: [id], onDelete: Cascade)
  channelId           String?      @db.Uuid
  channel             Channel?     @relation(fields: [channelId], references: [id], onDelete: SetNull)
  channelNameSnapshot String
  channelSlugSnapshot String
  title               String
  storagePath         String       @unique
  fileName            String
  mimeType            String
  containerFormat     String
  startedAt           DateTime
  endedAt             DateTime
  durationSeconds     Int?
  fileSizeBytes       BigInt?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([channelId, createdAt])
  @@index([createdAt])
}

model Favorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  channelId String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, channelId])
}

model SavedLayout {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String            @db.Uuid
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  layoutType LayoutType
  configJson Json
  items      SavedLayoutItem[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model SavedLayoutItem {
  id               String      @id @default(uuid()) @db.Uuid
  savedLayoutId    String      @db.Uuid
  savedLayout      SavedLayout @relation(fields: [savedLayoutId], references: [id], onDelete: Cascade)
  tileIndex        Int
  channelId        String?     @db.Uuid
  channel          Channel?    @relation(fields: [channelId], references: [id], onDelete: SetNull)
  preferredQuality String?
  isMuted          Boolean     @default(true)

  @@unique([savedLayoutId, tileIndex])
}

model PlaybackSession {
  id              String               @id @default(uuid()) @db.Uuid
  userId          String               @db.Uuid
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId       String?              @db.Uuid
  channel         Channel?             @relation(fields: [channelId], references: [id], onDelete: SetNull)
  sessionType     PlaybackSessionType
  playbackState   PlaybackSessionState
  selectedQuality String?
  isMuted         Boolean              @default(true)
  tileIndex       Int?
  failureKind     String?
  startedAt       DateTime             @default(now())
  lastSeenAt      DateTime             @default(now())
  endedAt         DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([endedAt, lastSeenAt])
  @@index([userId, endedAt, lastSeenAt])
  @@index([channelId, endedAt, lastSeenAt])
}

model AuditEvent {
  id          String    @id @default(uuid()) @db.Uuid
  actorUserId String?   @db.Uuid
  actorUser   User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorRole   UserRole?
  action      String
  targetType  String
  targetId    String?
  targetName  String?
  detailJson  Json?
  createdAt   DateTime  @default(now())

  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([action, createdAt])
}
