generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum LayoutType {
  LAYOUT_1X1
  LAYOUT_2X2
  LAYOUT_3X3
  LAYOUT_FOCUS_1_2
  LAYOUT_FOCUS_1_4
}

enum StreamPlaybackMode {
  DIRECT
  PROXY
}

enum ChannelSourceMode {
  MASTER_PLAYLIST
  MANUAL_VARIANTS
}

enum EpgSourceType {
  XMLTV
}

enum PlaybackSessionType {
  SINGLE_VIEW
  MULTIVIEW
}

enum PlaybackSessionState {
  idle
  loading
  playing
  buffering
  retrying
  error
}

model User {
  id               String           @id @default(uuid()) @db.Uuid
  email            String           @unique
  username         String           @unique
  passwordHash     String
  role             UserRole         @default(USER)
  favorites        Favorite[]
  savedLayouts     SavedLayout[]
  playbackSessions PlaybackSession[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model ChannelGroup {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  sortOrder Int       @default(0)
  channels  Channel[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Channel {
  id                String             @id @default(uuid()) @db.Uuid
  name              String
  slug              String             @unique
  logoUrl           String?
  sourceMode        ChannelSourceMode  @default(MASTER_PLAYLIST)
  masterHlsUrl      String?
  playbackMode      StreamPlaybackMode @default(DIRECT)
  upstreamUserAgent String?
  upstreamReferrer  String?
  upstreamHeaders   Json?
  groupId           String?            @db.Uuid
  group             ChannelGroup?      @relation(fields: [groupId], references: [id], onDelete: SetNull)
  epgSourceId       String?            @db.Uuid
  epgSource         EpgSource?         @relation(fields: [epgSourceId], references: [id], onDelete: SetNull)
  epgChannelId      String?
  isActive          Boolean            @default(true)
  sortOrder         Int                @default(0)
  qualityVariants   ChannelQualityVariant[]
  favorites         Favorite[]
  layoutItems       SavedLayoutItem[]
  playbackSessions  PlaybackSession[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([epgSourceId, epgChannelId])
}

model ChannelQualityVariant {
  id          String   @id @default(uuid()) @db.Uuid
  channelId   String   @db.Uuid
  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  label       String
  sortOrder   Int
  playlistUrl String
  width       Int?
  height      Int?
  bandwidth   Int?
  codecs      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([channelId, sortOrder])
  @@index([channelId, isActive, sortOrder])
}

model EpgSource {
  id                     String        @id @default(uuid()) @db.Uuid
  name                   String
  slug                   String        @unique
  sourceType             EpgSourceType @default(XMLTV)
  url                    String
  isActive               Boolean       @default(true)
  refreshIntervalMinutes Int           @default(360)
  requestUserAgent       String?
  requestReferrer        String?
  requestHeaders         Json?
  channels               Channel[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
}

model Favorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  channelId String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, channelId])
}

model SavedLayout {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String            @db.Uuid
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  layoutType LayoutType
  configJson Json
  items      SavedLayoutItem[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model SavedLayoutItem {
  id               String      @id @default(uuid()) @db.Uuid
  savedLayoutId    String      @db.Uuid
  savedLayout      SavedLayout @relation(fields: [savedLayoutId], references: [id], onDelete: Cascade)
  tileIndex        Int
  channelId        String?     @db.Uuid
  channel          Channel?    @relation(fields: [channelId], references: [id], onDelete: SetNull)
  preferredQuality String?
  isMuted          Boolean     @default(true)

  @@unique([savedLayoutId, tileIndex])
}

model PlaybackSession {
  id              String               @id @default(uuid()) @db.Uuid
  userId          String               @db.Uuid
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId       String?              @db.Uuid
  channel         Channel?             @relation(fields: [channelId], references: [id], onDelete: SetNull)
  sessionType     PlaybackSessionType
  playbackState   PlaybackSessionState
  selectedQuality String?
  isMuted         Boolean              @default(true)
  tileIndex       Int?
  failureKind     String?
  startedAt       DateTime             @default(now())
  lastSeenAt      DateTime             @default(now())
  endedAt         DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([endedAt, lastSeenAt])
  @@index([userId, endedAt, lastSeenAt])
  @@index([channelId, endedAt, lastSeenAt])
}
